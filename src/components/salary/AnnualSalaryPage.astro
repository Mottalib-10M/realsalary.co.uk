---
/**
 * Full-page component for annual salary landing pages.
 * Renders a complete <html> document (no <!DOCTYPE html> — the parent handles that).
 * Receives a single `page` prop of type AnnualSalaryPageData.
 */
import Header from '../layout/Header.astro';
import Footer from '../layout/Footer.astro';
import BaseHead from '../seo/BaseHead.astro';
import Breadcrumbs from '../ui/Breadcrumbs.astro';
import '../../styles/global.css';
import { type AnnualSalaryPageData } from '../../data/annual-salary-pages';
import {
  buildTitle,
  buildCanonical,
  SITE_NAME,
  SITE_URL,
  OG_IMAGE,
  OG_IMAGE_WIDTH,
  OG_IMAGE_HEIGHT,
  breadcrumbSchema,
  articleSchema,
  faqSchema,
  organizationSchema,
  personSchema,
  LAST_UPDATED,
} from '../../lib/seo';
import { formatCurrency, formatPercent } from '../../lib/format';
import {
  PERSONAL_ALLOWANCE,
  NI_PRIMARY_THRESHOLD,
  NI_UPPER_EARNINGS_LIMIT,
  TAX_YEAR,
} from '../../data/tax-rules-2026-27';

interface Props {
  page: AnnualSalaryPageData;
}

const { page } = Astro.props;

// ─── SEO ──────────────────────────────────────────────────────────────────
const annualF = page.annual.toLocaleString('en-GB');
const title = `£${annualF} a Year After Tax UK - Take Home Pay ${TAX_YEAR}`;
const metaTitle = buildTitle(title);
const description = `Earning £${annualF} a year? Your UK take home pay is ${page.englandFormatted.netMonthly}/month after tax and NI. Full ${TAX_YEAR} tax breakdown, Scotland comparison, and tips.`;
const canonical = buildCanonical(`/salary/${page.slug}`);

const breadcrumbItems = [
  { name: 'Home', url: SITE_URL },
  { name: 'Salary Pages', url: `${SITE_URL}/salary/` },
  { name: `£${annualF} a Year`, url: canonical },
];

// ─── Context helpers ────────────────────────────────────────────────────
const medianAnnual = 35000;
const percentOfMedian = Math.round((page.annual / medianAnnual) * 100);
const monthlyNet = page.england.netAnnual / 12;
const rentBudget30 = formatCurrency(monthlyNet * 0.3);
const mortgageMax = formatCurrency(page.annual * 4.5);
const monthlyNetF = formatCurrency(monthlyNet);
const annualNetF = formatCurrency(page.england.netAnnual);
const scotlandDiff = page.england.netAnnual - page.scotland.netAnnual;
const scotlandDiffF = formatCurrency(Math.abs(scotlandDiff));
const scotlandMore = scotlandDiff > 0;

// NI detail
const paysNI = page.annual > NI_PRIMARY_THRESHOLD;
const niableIncome = paysNI ? Math.min(page.annual, NI_UPPER_EARNINGS_LIMIT) - NI_PRIMARY_THRESHOLD : 0;

// Tax detail
const paysTax = page.annual > PERSONAL_ALLOWANCE;
const taxableIncome = paysTax ? page.annual - PERSONAL_ALLOWANCE : 0;

// ─── Variation index ────────────────────────────────────────────────────
function vi(amount: number, count: number): number {
  return ((amount * 3 + 3) * 7) % 997 % count;
}
const vIdx = vi(page.annual, 5);

// ─── FAQs ─────────────────────────────────────────────────────────────────
const faqs: { question: string; answer: string }[] = [];

// FAQ 1: take home pay
faqs.push({
  question: `What is the take home pay on £${annualF} a year?`,
  answer: `On a salary of ${page.annualFormatted} per year in England, your take home pay is ${page.englandFormatted.netAnnual} per year or ${page.englandFormatted.netMonthly} per month after income tax of ${page.englandFormatted.incomeTax} and National Insurance of ${page.englandFormatted.nationalInsurance}. Your effective tax rate is ${page.englandFormatted.effectiveTaxRate}.`,
});

// FAQ 2: monthly breakdown
faqs.push({
  question: `How much is £${annualF} a year per month?`,
  answer: `A salary of ${page.annualFormatted} per year is ${page.monthlyGross} per month before tax. After income tax and National Insurance, you take home approximately ${page.englandFormatted.netMonthly} per month in England for the ${TAX_YEAR} tax year.`,
});

// FAQ 3: hourly equivalent
faqs.push({
  question: `What is £${annualF} a year per hour?`,
  answer: `Based on a standard 37.5-hour working week, ${page.annualFormatted} per year works out to ${page.hourlyGross} per hour before tax.`,
});

// FAQ 4: tier-specific
if (page.tier === 'basic') {
  faqs.push({
    question: `Is £${annualF} a good salary in the UK?`,
    answer: `A salary of ${page.annualFormatted} is ${percentOfMedian}% of the UK median salary of ${formatCurrency(medianAnnual)}. ${page.annual >= medianAnnual ? 'This is at or above the national median.' : 'This is below the national median.'} Whether it is sufficient depends on your location, lifestyle, and financial commitments.`,
  });
} else if (page.tier === 'higher') {
  faqs.push({
    question: `What tax band is £${annualF} in?`,
    answer: `At ${page.annualFormatted}, your salary spans the basic rate (20%) and higher rate (40%) bands. The first ${formatCurrency(PERSONAL_ALLOWANCE)} is tax-free, then you pay 20% up to £50,270 and 40% on the remainder. Your marginal tax rate is ${page.englandFormatted.marginalTaxRate}.`,
  });
} else if (page.tier === 'taper') {
  faqs.push({
    question: `Why is my tax so high on £${annualF}?`,
    answer: `At ${page.annualFormatted}, you are in the personal allowance taper zone (£100,000–£125,140). Your personal allowance is reduced by £1 for every £2 earned above £100,000, creating an effective 60% marginal tax rate. Your personal allowance is ${formatCurrency(page.england.personalAllowance)}.`,
  });
} else if (page.tier === 'additional') {
  faqs.push({
    question: `How much tax do I pay on £${annualF}?`,
    answer: `At ${page.annualFormatted}, you have no personal allowance and pay income tax at 20%, 40%, and 45% across the three bands. Your total income tax is ${page.englandFormatted.incomeTax} and National Insurance is ${page.englandFormatted.nationalInsurance}. Combined deductions are ${page.englandFormatted.totalDeductions}.`,
  });
} else {
  faqs.push({
    question: `Do I pay tax on £${annualF} a year?`,
    answer: `${page.annualFormatted} is below the Personal Allowance of ${formatCurrency(PERSONAL_ALLOWANCE)}, so you pay no income tax. You may still pay National Insurance if your earnings exceed the NI threshold.`,
  });
}

// FAQ 5: Scotland comparison
faqs.push({
  question: `How much more tax do I pay in Scotland on £${annualF}?`,
  answer: scotlandMore
    ? `On ${page.annualFormatted}, you would take home ${scotlandDiffF} less per year in Scotland (${page.scotlandFormatted.netAnnual} vs ${page.englandFormatted.netAnnual} in England). Scotland has six income tax bands with rates from 19% to 48%.`
    : `On ${page.annualFormatted}, you would actually take home ${scotlandDiffF} more per year in Scotland (${page.scotlandFormatted.netAnnual} vs ${page.englandFormatted.netAnnual} in England). Scotland's starter rate of 19% is lower than England's basic rate of 20%.`,
});

// ─── Structured data ────────────────────────────────────────────────────
const schemas = [
  breadcrumbSchema(breadcrumbItems),
  articleSchema({ headline: title, description, url: canonical }),
  faqSchema(faqs),
  organizationSchema(),
  personSchema(),
];

// ─── Intro paragraph variants ───────────────────────────────────────────
const introVariants: Record<string, string[]> = {
  'below-pa': [
    `If you earn <strong>${page.annualFormatted} per year</strong> in the United Kingdom, your salary falls below the Personal Allowance of ${formatCurrency(PERSONAL_ALLOWANCE)}, meaning <strong>you pay no income tax</strong>. Your take-home pay is ${page.englandFormatted.netAnnual} per year or ${page.englandFormatted.netMonthly} per month. This guide covers what happens to your pay for the ${TAX_YEAR} tax year.`,
    `Earning <strong>${page.annualFormatted} a year</strong> puts your salary within the Personal Allowance, so no income tax is deducted from your wages. Your annual take-home is ${page.englandFormatted.netAnnual}, which works out to ${page.englandFormatted.netMonthly} each month. Below you will find the full ${TAX_YEAR} breakdown including NI and Scotland comparison.`,
    `On a gross salary of <strong>${page.annualFormatted}</strong>, you keep ${page.englandFormatted.netAnnual} after any National Insurance deductions. Because this income is below ${formatCurrency(PERSONAL_ALLOWANCE)}, no income tax applies for ${TAX_YEAR}. This page explains exactly how your pay is calculated.`,
    `A salary of <strong>${page.annualFormatted} per year</strong> means ${page.englandFormatted.netMonthly} reaches your bank account each month. With your earnings below the tax-free threshold, your effective tax rate is ${page.englandFormatted.effectiveTaxRate}. Read on for the complete ${TAX_YEAR} breakdown.`,
    `At <strong>${page.annualFormatted} a year</strong>, your entire salary sits within the ${TAX_YEAR} Personal Allowance. You owe no income tax, and your take-home pay is ${page.englandFormatted.netAnnual} annually (${page.englandFormatted.netMonthly} per month). This page covers your NI position, Scotland comparison, and practical context.`,
  ],
  basic: [
    `If you earn <strong>${page.annualFormatted} per year</strong> in the UK, your take-home pay is <strong>${annualNetF}</strong> annually or <strong>${monthlyNetF}</strong> per month after income tax and National Insurance. Your effective tax rate is ${page.englandFormatted.effectiveTaxRate}. This page provides the complete ${TAX_YEAR} breakdown.`,
    `On a gross salary of <strong>${page.annualFormatted}</strong>, you keep <strong>${annualNetF}</strong> after deductions of ${page.englandFormatted.totalDeductions}. That means <strong>${monthlyNetF}</strong> lands in your bank account each month for the ${TAX_YEAR} tax year.`,
    `Earning <strong>${page.annualFormatted} a year</strong> means <strong>${monthlyNetF}</strong> reaches your account monthly. After ${page.englandFormatted.incomeTax} in income tax and ${page.englandFormatted.nationalInsurance} in NI, your effective rate is ${page.englandFormatted.effectiveTaxRate}. Here is the full ${TAX_YEAR} analysis.`,
    `A UK salary of <strong>${page.annualFormatted}</strong> gives you a net annual income of <strong>${annualNetF}</strong>. You pay ${page.englandFormatted.incomeTax} in income tax and ${page.englandFormatted.nationalInsurance} in National Insurance. Below is your complete take-home pay breakdown for ${TAX_YEAR}.`,
    `With a salary of <strong>${page.annualFormatted} per year</strong>, your monthly take-home is approximately <strong>${monthlyNetF}</strong>. Your total deductions come to ${page.englandFormatted.totalDeductions}, giving an effective rate of ${page.englandFormatted.effectiveTaxRate}. All figures below use official HMRC ${TAX_YEAR} rates.`,
  ],
  higher: [
    `If you earn <strong>${page.annualFormatted} per year</strong>, your take-home pay is <strong>${annualNetF}</strong> annually or <strong>${monthlyNetF}</strong> per month. At this level you pay both basic rate (20%) and higher rate (40%) tax, giving an effective rate of ${page.englandFormatted.effectiveTaxRate} for ${TAX_YEAR}.`,
    `On <strong>${page.annualFormatted} a year</strong>, you keep <strong>${monthlyNetF} per month</strong> after total deductions of ${page.englandFormatted.totalDeductions}. Your salary crosses into the 40% higher rate band. This page provides the full ${TAX_YEAR} breakdown.`,
    `Earning <strong>${page.annualFormatted}</strong> puts you in the higher rate tax band. After income tax of ${page.englandFormatted.incomeTax} and NI of ${page.englandFormatted.nationalInsurance}, your net annual pay is <strong>${annualNetF}</strong>. Your effective rate is ${page.englandFormatted.effectiveTaxRate} for ${TAX_YEAR}.`,
    `A salary of <strong>${page.annualFormatted} per year</strong> means <strong>${monthlyNetF}</strong> each month after tax. You pay the higher rate of 40% on income above £50,270, and your marginal rate is ${page.englandFormatted.marginalTaxRate}. Full ${TAX_YEAR} analysis below.`,
    `At <strong>${page.annualFormatted}</strong>, your salary spans two tax bands. You take home <strong>${annualNetF}</strong> per year (${monthlyNetF}/month) with an effective rate of ${page.englandFormatted.effectiveTaxRate}. Below is your complete ${TAX_YEAR} tax breakdown for England and Scotland.`,
  ],
  taper: [
    `If you earn <strong>${page.annualFormatted} per year</strong>, you are in the personal allowance taper zone. Your take-home pay is <strong>${annualNetF}</strong> annually (${monthlyNetF}/month). The taper creates an effective 60% marginal rate. Here is your full ${TAX_YEAR} breakdown.`,
    `On <strong>${page.annualFormatted} a year</strong>, your personal allowance is reduced to ${formatCurrency(page.england.personalAllowance)}, pushing your effective deductions higher than you might expect. You keep <strong>${monthlyNetF} per month</strong>. This page explains the ${TAX_YEAR} taper rules in detail.`,
    `Earning <strong>${page.annualFormatted}</strong> places you in the 60% marginal rate zone where your Personal Allowance is being tapered away. After deductions of ${page.englandFormatted.totalDeductions}, your net pay is <strong>${annualNetF}</strong>. Full ${TAX_YEAR} analysis below.`,
    `A salary of <strong>${page.annualFormatted} per year</strong> means <strong>${monthlyNetF}</strong> each month, but your marginal rate is effectively 60% due to the personal allowance taper. Your personal allowance has been reduced to ${formatCurrency(page.england.personalAllowance)} for ${TAX_YEAR}.`,
    `At <strong>${page.annualFormatted}</strong>, the personal allowance taper significantly affects your take-home. You receive <strong>${annualNetF}</strong> per year after ${page.englandFormatted.totalDeductions} in deductions. Your effective rate is ${page.englandFormatted.effectiveTaxRate}. ${TAX_YEAR} breakdown follows.`,
  ],
  additional: [
    `If you earn <strong>${page.annualFormatted} per year</strong>, you pay the additional rate of 45% on income above £125,140. Your take-home pay is <strong>${annualNetF}</strong> annually (${monthlyNetF}/month) with an effective rate of ${page.englandFormatted.effectiveTaxRate} for ${TAX_YEAR}.`,
    `On <strong>${page.annualFormatted} a year</strong>, your personal allowance is zero and you pay tax at 20%, 40%, and 45% across three bands. You keep <strong>${monthlyNetF} per month</strong> after deductions of ${page.englandFormatted.totalDeductions}. Full ${TAX_YEAR} breakdown below.`,
    `Earning <strong>${page.annualFormatted}</strong> puts you in the additional rate band. After income tax of ${page.englandFormatted.incomeTax} and NI of ${page.englandFormatted.nationalInsurance}, your net annual pay is <strong>${annualNetF}</strong>. Your effective rate is ${page.englandFormatted.effectiveTaxRate} for ${TAX_YEAR}.`,
    `A salary of <strong>${page.annualFormatted} per year</strong> results in total deductions of ${page.englandFormatted.totalDeductions}, leaving you with <strong>${monthlyNetF} per month</strong>. At this level, your marginal rate is ${page.englandFormatted.marginalTaxRate}. All ${TAX_YEAR} figures below.`,
    `At <strong>${page.annualFormatted}</strong>, you pay across all three income tax bands including the 45% additional rate. Your take-home is <strong>${annualNetF}</strong> per year with an effective rate of ${page.englandFormatted.effectiveTaxRate}. Here is the complete ${TAX_YEAR} analysis.`,
  ],
};

const introHtml = (introVariants[page.tier] ?? introVariants['basic'])[vIdx];

// ─── "What it means" paragraph variants ─────────────────────────────────
const contextVariants: Record<string, string[][]> = {
  'below-pa': [
    [
      `A salary of ${page.annualFormatted} is ${percentOfMedian}% of the UK median of ${formatCurrency(medianAnnual)}. This income level is common for part-time roles, apprenticeships, or entry-level positions with reduced hours. Many people at this salary work in retail, hospitality, or care work.`,
      `At ${page.englandFormatted.netMonthly} per month take-home, following the 30% housing rule gives a rent budget of ${rentBudget30}. In most UK regions outside London, shared accommodation or rooms in lower-cost areas fall within this range.`,
      `If this is your primary income, you may be eligible for Universal Credit or other means-tested benefits. It is worth using the gov.uk benefits calculator to check your entitlements, as these can meaningfully supplement your take-home pay.`,
    ],
    [
      `Earning ${page.annualFormatted} per year places your income below the national median of ${formatCurrency(medianAnnual)}. At ${percentOfMedian}% of the median, this salary is typical for those working fewer hours or in entry-level roles.`,
      `Your monthly take-home of ${page.englandFormatted.netMonthly} means careful budgeting is essential. A housing spend of ${rentBudget30} (30% of net) is realistic in lower-cost parts of the UK. Council Tax reductions may also be available at this income.`,
      `Building emergency savings at this income level can be challenging, but even small regular deposits add up. Setting aside ${formatCurrency(monthlyNet * 0.05)} per month creates a meaningful buffer over time.`,
    ],
    [
      `At ${page.annualFormatted} per year (${percentOfMedian}% of the UK median), your take-home of ${page.englandFormatted.netMonthly} each month covers essential expenses in many parts of the UK outside London and the South East.`,
      `The 30% housing rule suggests a rent budget of ${rentBudget30}. Combined with Council Tax Reduction eligibility and potentially free prescriptions through the NHS low income scheme, your effective spending power may be higher than the headline figure.`,
      `If you are looking to increase your earnings, upskilling through free government-funded courses or apprenticeships can open doors to roles with higher pay. Many employers also offer progression frameworks that lead to salary increases over time.`,
    ],
  ],
  basic: [
    [
      `A salary of ${page.annualFormatted} represents ${percentOfMedian}% of the UK median (${formatCurrency(medianAnnual)}). ${page.annual >= medianAnnual ? 'This is at or above the national average, providing a comfortable standard of living in most UK regions.' : 'While below the national median, this income supports a reasonable standard of living in many parts of the country.'}`,
      `With monthly take-home pay of ${page.englandFormatted.netMonthly}, the 30% housing rule suggests a rent or mortgage budget of <strong>${rentBudget30}</strong>. Based on typical lending multiples (4.5x salary), you could borrow up to <strong>${mortgageMax}</strong> for a mortgage.`,
      `Building financial security on ${page.annualFormatted} is achievable with disciplined budgeting. Setting aside 10% of your net pay (${formatCurrency(monthlyNet * 0.1)}/month) builds an emergency fund of ${formatCurrency(monthlyNet * 0.1 * 12)} per year. Maximising employer pension contributions is one of the most effective ways to grow your long-term wealth at this income level.`,
    ],
    [
      `Earning ${page.annualFormatted} places you at ${percentOfMedian}% of the UK median salary. ${page.annual >= medianAnnual ? 'Your income matches or exceeds what the average full-time UK worker earns.' : 'Your salary is approaching the national median, typical for early to mid-career professionals.'} Your net monthly income of ${page.englandFormatted.netMonthly} provides practical spending power across most UK regions.`,
      `For housing, ${rentBudget30} per month (30% of net) opens doors to one-bedroom flats in most cities outside London. Mortgage lenders would typically consider lending up to ${mortgageMax} at 4.5 times your gross salary, depending on your deposit and credit profile.`,
      `At this income, pension salary sacrifice is particularly effective. Every £100 contributed via salary sacrifice saves you £28 in tax and NI combined, meaning the real cost to you is just £72. Over a career, these contributions compound significantly.`,
    ],
    [
      `Your salary of ${page.annualFormatted} a year is ${percentOfMedian}% of the UK median. ${page.annual >= medianAnnual ? 'This puts you in line with or above the typical full-time earner.' : 'You are working towards the national median, and even small pay rises will make a meaningful difference to your take-home.'} With ${page.englandFormatted.netMonthly} each month after tax, here is how that translates into everyday spending power.`,
      `Following the 30% rule for housing, your budget is ${rentBudget30} per month. Mortgage capacity at 4.5x salary reaches ${mortgageMax}. In northern England, the Midlands, Wales, and Scotland, this budget comfortably covers a one or two-bedroom property.`,
