---
import { TAX_YEAR } from '../../data/tax-rules-2026-27';
import { footerSalaryLinks as salaryLinks, footerHourlyLinks as hourlyLinks, footerAnnualLinks as annualLinks, footerInfoLinks as infoLinks } from '../../data/nav';

const topCalculators = [
  { href: '/', label: 'Salary Calculator' },
  { href: '/take-home-pay/', label: 'Take-Home Pay' },
  { href: '/income-tax/', label: 'Income Tax' },
  { href: '/national-insurance/', label: 'National Insurance' },
  { href: '/pension-contribution/', label: 'Pension' },
  { href: '/employer-cost/', label: 'Employer Cost' },
  { href: '/scottish-tax-calculator/', label: 'Scottish Tax' },
  { href: '/calculators/', label: 'All Calculators' },
];
---

<footer class="border-t border-gray-200 bg-gray-50 dark:border-gray-800 dark:bg-gray-950">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div>
        <a href="/" class="text-lg font-bold text-navy-700 dark:text-white">Real Salary</a>
        <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
          Free UK salary and tax calculators. Updated for the {TAX_YEAR} tax year.
          All rates sourced from gov.uk.
        </p>
      </div>

      <nav aria-label="Footer navigation" class="contents">
        <!-- Calculators -->
        <div>
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Calculators</h3>
          <ul class="mt-3 space-y-2">
            {topCalculators.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-gray-500 hover:text-navy-600 dark:text-gray-400 dark:hover:text-navy-300">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Salary Pages -->
        <div>
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Salary Pages</h3>
          <ul class="mt-3 space-y-2">
            {salaryLinks.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-gray-500 hover:text-navy-600 dark:text-gray-400 dark:hover:text-navy-300">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
          <h4 class="mt-4 text-xs font-semibold uppercase tracking-wide text-gray-700 dark:text-gray-300">Annual</h4>
          <ul class="mt-2 space-y-2">
            {annualLinks.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-gray-500 hover:text-navy-600 dark:text-gray-400 dark:hover:text-navy-300">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
          <h4 class="mt-4 text-xs font-semibold uppercase tracking-wide text-gray-700 dark:text-gray-300">Hourly</h4>
          <ul class="mt-2 space-y-2">
            {hourlyLinks.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-gray-500 hover:text-navy-600 dark:text-gray-400 dark:hover:text-navy-300">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Information -->
        <div>
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Information</h3>
          <ul class="mt-3 space-y-2">
            {infoLinks.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-gray-500 hover:text-navy-600 dark:text-gray-400 dark:hover:text-navy-300">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </nav>
    </div>

    <div class="mt-10 border-t border-gray-200 pt-6 dark:border-gray-800">
      <p class="text-center text-xs text-gray-400 dark:text-gray-500">
        &copy; {new Date().getFullYear()} Real Salary. All calculations are estimates based on HMRC {TAX_YEAR} rates.
        This site does not provide financial advice. Verify with HMRC or a qualified accountant.
      </p>
    </div>
  </div>
</footer>
