---
interface Props {
  faqs: { question: string; answer: string }[];
}

const { faqs } = Astro.props;
---

<div class="divide-y divide-gray-200 dark:divide-gray-800">
  {faqs.map((faq) => (
    <details class="group py-4">
      <summary class="flex cursor-pointer items-center justify-between text-left font-medium text-gray-900 dark:text-white">
        <span>{faq.question}</span>
        <svg
          class="ml-4 h-5 w-5 flex-shrink-0 text-gray-400 transition-transform group-open:rotate-180"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
        </svg>
      </summary>
      <p class="mt-3 text-gray-500 dark:text-gray-400">
        {faq.answer}
      </p>
    </details>
  ))}
</div>
