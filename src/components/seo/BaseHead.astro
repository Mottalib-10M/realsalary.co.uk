---
/**
 * Shared <head> snippet for Microsoft Clarity and Bing Webmaster verification.
 * Include this in every page's <head> to ensure consistent tracking.
 */
import { CLARITY_PROJECT_ID, BING_VERIFY_CODE } from '../../lib/seo';

interface Props {
  slug: string;
  pageType?: string;
}

const { slug, pageType = 'page' } = Astro.props;
---

{BING_VERIFY_CODE && <meta name="msvalidate.01" content={BING_VERIFY_CODE} />}

{CLARITY_PROJECT_ID && (
  <script type="text/javascript" set:html={`
    (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y)})(window,document,"clarity","script","${CLARITY_PROJECT_ID}");
    clarity("set","language","en-GB");
    clarity("set","page_type","${pageType}");
    clarity("set","page_path","${slug}");
  `} />
)}
