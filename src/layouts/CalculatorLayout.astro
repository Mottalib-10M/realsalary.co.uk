---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import FAQAccordion from '../components/ui/FAQAccordion.astro';
import RelatedCalculators from '../components/ui/RelatedCalculators.astro';
import '../styles/global.css';
import BaseHead from '../components/seo/BaseHead.astro';
import Breadcrumbs from '../components/ui/Breadcrumbs.astro';
import { buildTitle, buildCanonical, SITE_NAME, SITE_URL, OG_IMAGE, OG_IMAGE_WIDTH, OG_IMAGE_HEIGHT, webApplicationSchema, faqSchema, breadcrumbSchema, websiteSearchSchema, organizationSchema, personSchema, LAST_UPDATED } from '../lib/seo';

interface Props {
  slug: string;
  title: string;
  metaTitle: string;
  metaDescription: string;
  h1: string;
  intro: string;
  faqs: { question: string; answer: string }[];
}

const { slug, title, metaTitle, metaDescription, h1, intro, faqs } = Astro.props;
const pageTitle = buildTitle(metaTitle);
const canonical = buildCanonical(slug);

const breadcrumbItems = [
  { name: 'Home', url: SITE_URL },
  { name: title, url: canonical },
];

const schemas: object[] = [
  webApplicationSchema(title, metaDescription, canonical),
  faqSchema(faqs),
  breadcrumbSchema(breadcrumbItems),
  organizationSchema(),
  personSchema(),
];

// Add WebSite schema with SearchAction on homepage for Google sitelinks search box
if (slug === '/') {
  schemas.push(websiteSearchSchema());
}
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={metaDescription} />
  <meta name="author" content="Mottalib Radif" />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={metaTitle} />
  <meta property="og:description" content={metaDescription} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={SITE_NAME} />
  <meta property="og:locale" content="en_GB" />
  <meta property="og:image" content={OG_IMAGE} />
  <meta property="og:image:width" content={OG_IMAGE_WIDTH} />
  <meta property="og:image:height" content={OG_IMAGE_HEIGHT} />
  <meta property="og:image:alt" content={`${metaTitle} - UK Salary Calculator`} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={metaTitle} />
  <meta name="twitter:description" content={metaDescription} />
  <meta name="twitter:image" content={OG_IMAGE} />

  <BaseHead slug={slug} pageType="calculator" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Preload Inter font (self-hosted) -->
  <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/inter-700.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Manifest -->
  <link rel="manifest" href="/manifest.webmanifest" />

  <!-- Structured Data -->
  {schemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <!-- Plausible Analytics (uncomment when ready to launch)
  <script defer data-domain="realsalary.co.uk" src="https://plausible.io/js/script.js"></script>
  -->

</head>
<body class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
  <a href="#main-content" class="skip-link bg-navy-600 text-white">Skip to calculator</a>

  <Header />

  <main id="main-content" class="mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-12">
    <!-- Page header -->
    <div class="mb-8">
      <Breadcrumbs items={breadcrumbItems} />
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl dark:text-white">
        {h1}
      </h1>
      <p class="mt-3 text-lg text-gray-500 dark:text-gray-400">
        {intro}
      </p>
    </div>

    <!-- Calculator slot -->
    <slot />

    <!-- Author byline -->
    <div class="mt-8 flex items-center gap-4 rounded-lg border border-gray-200 dark:border-gray-700 px-5 py-4">
      <img src="/team/mottalib-radif.jpg" alt="Mottalib Radif" class="h-12 w-12 rounded-full object-cover" width="48" height="48" loading="lazy" />
      <div class="text-sm">
        <p class="font-semibold text-gray-900 dark:text-white">Written by <a href="/about/" class="text-navy-600 hover:underline dark:text-navy-400">Mottalib Radif</a></p>
        <p class="text-gray-500 dark:text-gray-400">MBA INSEAD &middot; Finance Enthusiast</p>
      </div>
    </div>

    <!-- Tax year stamp -->
    <p class="mt-4 text-sm text-gray-400 dark:text-gray-500">
      {LAST_UPDATED}
    </p>

    <!-- Rich SEO content slot -->
    <slot name="content" />

    <!-- FAQs -->
    {faqs.length > 0 && (
      <section class="mt-12" aria-labelledby="faq-heading">
        <h2 id="faq-heading" class="text-2xl font-bold text-gray-900 dark:text-white">
          Frequently Asked Questions
        </h2>
        <div class="mt-6">
          <FAQAccordion faqs={faqs} />
        </div>
      </section>
    )}

    <!-- Related calculators -->
    <RelatedCalculators slug={slug} />

    <!-- AdSense placeholder (activation pending traffic threshold) -->
    <div class="mt-8" data-ad-slot="below-faqs" aria-hidden="true">
      <!-- AdSense activation pending traffic threshold; affiliate program registration pending. -->
    </div>
  </main>

  <Footer />
</body>
</html>
