---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';
import { SITE_NAME, SITE_URL } from '../lib/seo';
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Page Not Found - {SITE_NAME}</title>
  <meta name="description" content="The page you are looking for does not exist or has been moved." />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/inter-700.woff2" as="font" type="font/woff2" crossorigin />
</head>
<body class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
  <a href="#main-content" class="skip-link bg-navy-600 text-white">Skip to content</a>
  <Header />

  <main id="main-content" class="flex min-h-[60vh] items-center justify-center px-4">
    <div class="mx-auto max-w-lg text-center">
      <p class="text-8xl font-bold text-navy-200 dark:text-navy-800">404</p>
      <h1 class="mt-4 text-2xl font-bold text-gray-900 dark:text-white">Page Not Found</h1>
      <p class="mt-3 leading-relaxed text-gray-500 dark:text-gray-400">
        The page you are looking for does not exist or has been moved.
        Use the links below to find what you need.
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-navy-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-navy-700"
        >
          Salary Calculator
        </a>
        <a
          href="/about/"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-gray-100 px-5 py-2.5 text-sm font-semibold text-gray-700 transition-colors hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
        >
          About
        </a>
        <a
          href="/guides/"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-gray-100 px-5 py-2.5 text-sm font-semibold text-gray-700 transition-colors hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
        >
          Guides
        </a>
      </div>

      <div class="mt-10 text-sm text-gray-400 dark:text-gray-500">
        <p>Popular calculators:</p>
        <div class="mt-2 flex flex-wrap justify-center gap-x-4 gap-y-1">
          <a href="/take-home-pay/" class="transition-colors hover:text-navy-600 dark:hover:text-navy-400">Take-Home Pay</a>
          <a href="/income-tax/" class="transition-colors hover:text-navy-600 dark:hover:text-navy-400">Income Tax</a>
          <a href="/national-insurance/" class="transition-colors hover:text-navy-600 dark:hover:text-navy-400">National Insurance</a>
          <a href="/student-loan/" class="transition-colors hover:text-navy-600 dark:hover:text-navy-400">Student Loan</a>
        </div>
      </div>

      <p class="mt-8 text-xs text-gray-400 dark:text-gray-500">
        Broken link? Report it to{" "}
        <a href="mailto:contact@realsalary.co.uk" class="text-navy-600 hover:underline dark:text-navy-400">
          contact@realsalary.co.uk
        </a>
      </p>
    </div>
  </main>

  <Footer />
</body>
</html>
