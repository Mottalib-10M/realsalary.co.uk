---
/**
 * Dynamic route for hourly rate landing pages.
 * Generates 20 static pages at build time for the most searched UK hourly rates.
 */
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import BaseHead from '../../components/seo/BaseHead.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import '../../styles/global.css';
import { generateHourlyRatePages, type HourlyRatePageData } from '../../data/hourly-rate-pages';
import {
  buildTitle,
  buildCanonical,
  SITE_NAME,
  SITE_URL,
  OG_IMAGE,
  OG_IMAGE_WIDTH,
  OG_IMAGE_HEIGHT,
  breadcrumbSchema,
  articleSchema,
  faqSchema,
  organizationSchema,
  personSchema,
  LAST_UPDATED,
} from '../../lib/seo';
import { formatCurrency, formatPercent } from '../../lib/format';
import {
  PERSONAL_ALLOWANCE,
  NI_PRIMARY_THRESHOLD,
  NI_UPPER_EARNINGS_LIMIT,
  NI_MAIN_RATE,
  NI_ADDITIONAL_RATE,
  TAX_YEAR,
} from '../../data/tax-rules-2026-27';

export function getStaticPaths() {
  const pages = generateHourlyRatePages();
  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

interface Props {
  page: HourlyRatePageData;
}

const { page } = Astro.props;

// ─── SEO ──────────────────────────────────────────────────────────────────
const title = `\u00A3${page.hourlyRate} Per Hour After Tax UK ${TAX_YEAR} - Salary & Tax Breakdown`;
const metaTitle = buildTitle(title);
const description = `At \u00A3${page.hourlyRate}/hr you earn ${page.annualFormatted} a year. Your UK take home is ${page.englandFormatted.netMonthly}/month after income tax and NI. Full ${TAX_YEAR} breakdown with tax bands and Scotland comparison.`;
const canonical = buildCanonical(`/hourly/${page.slug}`);

const breadcrumbItems = [
  { name: 'Home', url: SITE_URL },
  { name: 'Hourly Rates', url: `${SITE_URL}/hourly/` },
  { name: `\u00A3${page.hourlyRate} Per Hour`, url: canonical },
];

const article = articleSchema({
  headline: title,
  description,
  url: canonical,
});

// ─── Context helpers ────────────────────────────────────────────────────
const annualGross = page.annualEquivalent;
const monthlyGross = annualGross / 12;
const weeklyGross = annualGross / 52;
const monthlyNet = page.england.netAnnual / 12;
const weeklyNet = page.england.netAnnual / 52;
const dailyNet = page.england.netAnnual / 260;
const paysTax = annualGross > PERSONAL_ALLOWANCE;
const paysNI = annualGross > NI_PRIMARY_THRESHOLD;
const taxableIncome = paysTax ? annualGross - PERSONAL_ALLOWANCE : 0;
const niableIncome = paysNI ? Math.min(annualGross, NI_UPPER_EARNINGS_LIMIT) - NI_PRIMARY_THRESHOLD : 0;
const ctaGross = annualGross;

// Minimum wage context
const nlw2026 = 12.21;
const nlwAnnual = nlw2026 * 52 * 37.5;
const isAboveNLW = page.hourlyRate >= nlw2026;
const medianHourly = 17.94; // ONS 2024 median hourly rate for full-time UK employees
const isAboveMedian = page.hourlyRate >= medianHourly;

// ─── Rate-tiered prose context ──────────────────────────────────────────
type RateTier = 'near-minimum' | 'entry-average' | 'above-median' | 'skilled-professional' | 'senior-specialist' | 'executive';

function getRateTier(rate: number): RateTier {
  if (rate <= 12) return 'near-minimum';
  if (rate <= 17) return 'entry-average';
  if (rate <= 25) return 'above-median';
  if (rate <= 40) return 'skilled-professional';
  if (rate <= 75) return 'senior-specialist';
  return 'executive';
}

const rateTier = getRateTier(page.hourlyRate);

// ─── FAQs (unique per hourly rate level) ─────────────────────────────────
const faqs: { question: string; answer: string }[] = [];

// Universal FAQs that adapt to the specific rate
faqs.push({
  question: `What is ${page.hourlyFormatted} per hour as an annual salary?`,
  answer: `${page.hourlyFormatted} per hour equals ${page.annualFormatted} per year, based on a standard 37.5-hour working week (${page.hourlyFormatted} \u00D7 37.5 hours \u00D7 52 weeks). This is the gross annual salary before any tax or National Insurance deductions for the ${TAX_YEAR} tax year.`,
});

faqs.push({
  question: `How much do I take home on ${page.hourlyFormatted} per hour?`,
  answer: `On ${page.hourlyFormatted} per hour (${page.annualFormatted} per year) in England, your take-home pay is approximately ${page.englandFormatted.netMonthly} per month or ${page.englandFormatted.netHourly} per hour after income tax and National Insurance for the ${TAX_YEAR} tax year.`,
});

// Rate-specific FAQs
if (rateTier === 'near-minimum') {
  faqs.push({
    question: `Is ${page.hourlyFormatted} per hour above the minimum wage in the UK?`,
    answer: `The National Living Wage (NLW) for workers aged 21 and over is \u00A312.21 per hour from April 2026. At ${page.hourlyFormatted} per hour, your rate is ${page.hourlyRate >= nlw2026 ? 'at or above' : 'below'} the NLW. ${page.hourlyRate < nlw2026 ? 'If you are aged 21 or over working full-time, your employer must pay at least \u00A312.21 per hour.' : 'You are earning at or above the legal minimum for full-time workers aged 21+.'}`,
  });
  faqs.push({
    question: `Do I pay tax on ${page.hourlyFormatted} per hour?`,
    answer: `On ${page.hourlyFormatted} per hour (${page.annualFormatted} per year), ${paysTax ? `you pay ${page.englandFormatted.incomeTax} in income tax per year because your annual salary exceeds the Personal Allowance of ${formatCurrency(PERSONAL_ALLOWANCE)}.` : `you pay no income tax because your annual equivalent of ${page.annualFormatted} is below the Personal Allowance of ${formatCurrency(PERSONAL_ALLOWANCE)}.`} ${paysNI ? `You also pay ${page.englandFormatted.nationalInsurance} in National Insurance.` : 'You also pay no National Insurance as your earnings are below the Primary Threshold.'}`,
  });
  faqs.push({
    question: `Can I live on ${page.hourlyFormatted} per hour in the UK?`,
    answer: `On ${page.hourlyFormatted} per hour full-time, your monthly take-home is approximately ${page.englandFormatted.netMonthly}. This is challenging in high-cost areas like London, where average rents for a room exceed \u00A3700/month. In lower-cost regions such as the North East or Wales, it is more manageable. You may also be eligible for Universal Credit or other means-tested benefits to supplement your income.`,
  });
} else if (rateTier === 'entry-average') {
  faqs.push({
    question: `Is ${page.hourlyFormatted} an hour a good wage in the UK?`,
    answer: `The UK median hourly rate for full-time employees is approximately \u00A317.94 (ONS data). At ${page.hourlyFormatted} per hour, your rate is ${isAboveMedian ? 'above' : 'below'} the national median. ${page.hourlyRate >= 15 ? 'This is a reasonable wage for many entry-level to mid-level roles across the UK, particularly outside London.' : 'This is typical of entry-level full-time roles, retail, hospitality, and care sector positions.'}`,
  });
  faqs.push({
    question: `How much tax is deducted from ${page.hourlyFormatted} per hour?`,
    answer: `On ${page.hourlyFormatted} per hour (${page.annualFormatted} per year), you pay ${page.englandFormatted.incomeTax} in income tax and ${page.englandFormatted.nationalInsurance} in National Insurance per year. Your effective tax rate is ${page.englandFormatted.effectiveTaxRate}, meaning you keep ${page.englandFormatted.netHourly} of every ${page.hourlyFormatted} earned.`,
  });
  faqs.push({
    question: `What jobs pay ${page.hourlyFormatted} per hour in the UK?`,
    answer: `Roles paying around ${page.hourlyFormatted} per hour include experienced retail staff, warehouse operatives, administrative assistants, teaching assistants, care workers with experience, junior tradespeople, and entry-level office roles. Many NHS Band 2-4 positions and local government roles also pay in this range.`,
  });
} else if (rateTier === 'above-median') {
  faqs.push({
    question: `Is ${page.hourlyFormatted} per hour above average in the UK?`,
    answer: `Yes. The UK median hourly rate for full-time employees is approximately \u00A317.94. At ${page.hourlyFormatted} per hour (${page.annualFormatted} per year), you are earning above the national median. This rate is typical of skilled roles, mid-level professionals, and experienced workers across many sectors.`,
  });
  faqs.push({
    question: `What is the effective tax rate on ${page.hourlyFormatted} per hour?`,
    answer: `On ${page.hourlyFormatted} per hour (${page.annualFormatted} per year), your effective tax rate in England is ${page.englandFormatted.effectiveTaxRate}. This includes ${page.englandFormatted.incomeTax} in income tax and ${page.englandFormatted.nationalInsurance} in National Insurance per year. Your net hourly rate after all deductions is ${page.englandFormatted.netHourly}.`,
  });
  faqs.push({
    question: `What is the difference between ${page.hourlyFormatted} per hour in England and Scotland?`,
    answer: `On ${page.hourlyFormatted} per hour (${page.annualFormatted} per year), your net annual pay in England is ${page.englandFormatted.netAnnual} compared to ${page.scotlandFormatted.netAnnual} in Scotland. The difference is ${formatCurrency(Math.abs(page.england.netAnnual - page.scotland.netAnnual))} per year due to Scotland's different income tax bands.`,
  });
} else if (rateTier === 'skilled-professional') {
  faqs.push({
    question: `Am I a higher rate taxpayer on ${page.hourlyFormatted} per hour?`,
    answer: `At ${page.hourlyFormatted} per hour (${page.annualFormatted} per year), ${annualGross > 50270 ? 'yes, part of your income falls in the Higher Rate tax band (40%). Any earnings above \u00A350,270 per year are taxed at 40% instead of the basic rate of 20%.' : 'no, your income falls within the Basic Rate tax band (20%). The Higher Rate threshold starts at \u00A350,270 per year.'} Your total income tax is ${page.englandFormatted.incomeTax} per year.`,
  });
  faqs.push({
    question: `How does pension salary sacrifice help at ${page.hourlyFormatted} per hour?`,
    answer: `At ${page.hourlyFormatted} per hour (${page.annualFormatted} per year), pension salary sacrifice reduces your gross pay before tax and NI are calculated. ${annualGross > 50270 ? 'Since part of your income is taxed at 40%, every \u00A3100 you sacrifice saves \u00A340 in tax plus \u00A38 in NI (\u00A32 if above the UEL), so a \u00A3100 pension contribution costs you as little as \u00A352 in take-home pay.' : 'Every \u00A3100 you sacrifice saves \u00A320 in income tax and \u00A38 in NI, so a \u00A3100 pension contribution costs you only \u00A372 in take-home pay.'}`,
  });
  faqs.push({
    question: `What professional roles pay ${page.hourlyFormatted} per hour?`,
    answer: `Roles in the ${page.hourlyFormatted} per hour range include qualified accountants, experienced software developers, project managers, engineering professionals, NHS Band 7-8 positions, senior teachers, and mid-level legal and financial services roles. Contract and freelance rates in these fields are often higher to account for holiday pay and benefits.`,
  });
} else if (rateTier === 'senior-specialist') {
  faqs.push({
    question: `How much of ${page.hourlyFormatted} per hour do I lose to tax?`,
    answer: `On ${page.hourlyFormatted} per hour (${page.annualFormatted} per year), you pay ${page.englandFormatted.totalDeductions} in total deductions per year (income tax: ${page.englandFormatted.incomeTax}, National Insurance: ${page.englandFormatted.nationalInsurance}). Your effective tax rate is ${page.englandFormatted.effectiveTaxRate}, leaving you with ${page.englandFormatted.netHourly} per hour after tax.`,
  });
  faqs.push({
    question: `Is ${page.hourlyFormatted} per hour considered a high salary in the UK?`,
    answer: `Yes. ${page.hourlyFormatted} per hour equates to ${page.annualFormatted} per year, which places you well above the UK median salary of approximately \u00A335,000. This level of pay is typical of senior management, specialist consultants, experienced legal and medical professionals, and senior technology roles.`,
  });
  faqs.push({
    question: `Should I use a limited company at ${page.hourlyFormatted} per hour?`,
    answer: `At ${page.hourlyFormatted} per hour, the decision between employment and operating through a limited company depends on your working arrangements. If you are a contractor, a limited company may be more tax-efficient, allowing you to take a combination of salary and dividends. However, IR35 rules may apply if HMRC considers you effectively employed. Seek professional advice from a qualified accountant.`,
  });
} else {
  faqs.push({
    question: `What is the marginal tax rate on ${page.hourlyFormatted} per hour?`,
    answer: `At ${page.hourlyFormatted} per hour (${page.annualFormatted} per year), your marginal tax rate is ${page.englandFormatted.marginalTaxRate}. This means for every additional \u00A31 earned, you lose ${page.englandFormatted.marginalTaxRate} to income tax and National Insurance combined. ${annualGross > 100000 ? 'Note: between \u00A3100,000 and \u00A3125,140, the effective marginal rate reaches 60% due to the Personal Allowance taper.' : ''}`,
  });
  faqs.push({
    question: `How can I reduce my tax bill on ${page.hourlyFormatted} per hour?`,
    answer: `At ${page.hourlyFormatted} per hour (${page.annualFormatted} per year), key tax-reduction strategies include: maximising pension contributions (which receive tax relief at your marginal rate), using your full ISA allowance of \u00A320,000 per year, making charitable donations via Gift Aid, and considering salary sacrifice for benefits like electric vehicles or additional pension contributions. ${annualGross > 100000 ? 'Pension contributions above the \u00A3100,000 threshold can be particularly effective as they restore your Personal Allowance.' : ''}`,
  });
  faqs.push({
    question: `What type of roles pay ${page.hourlyFormatted} per hour in the UK?`,
    answer: `Roles at ${page.hourlyFormatted} per hour (${page.annualFormatted} per year) include C-suite executives, senior partners in law and consulting firms, specialist medical consultants, highly experienced technology architects, investment banking professionals, and senior management in large organisations. Contract and freelance professionals in IT, law, and finance can also command this rate.`,
  });
}

const faqStructuredData = faqSchema(faqs);

const schemas = [
  breadcrumbSchema(breadcrumbItems),
  article,
  faqStructuredData,
  organizationSchema(),
  personSchema(),
];

// ─── Pre-computed strings for template section ───────────────────────────
// Avoids template literals with ${} inside JSX expression containers,
// which can confuse esbuild's parser during the Astro build.
const paContext = annualGross <= PERSONAL_ALLOWANCE
  ? 'falls within the Personal Allowance, meaning you pay no income tax on this income'
  : 'is above the Personal Allowance of ' + formatCurrency(PERSONAL_ALLOWANCE) + ', so you pay income tax on the portion above this threshold';

const paTaperNote = annualGross > 100000
  ? ' Be aware that between \u00A3100,000 and \u00A3125,140, the Personal Allowance is tapered away at a rate of \u00A31 for every \u00A32 earned above \u00A3100,000, creating an effective marginal rate of 60%. Pension contributions above this threshold can restore your Personal Allowance.'
  : '';
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{metaTitle}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Mottalib Radif" />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="article" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={SITE_NAME} />
  <meta property="og:locale" content="en_GB" />
  <meta property="og:image" content={OG_IMAGE} />
  <meta property="og:image:width" content={OG_IMAGE_WIDTH} />
  <meta property="og:image:height" content={OG_IMAGE_HEIGHT} />
  <meta property="og:image:alt" content={`${page.hourlyFormatted} per hour after tax UK - hourly rate breakdown`} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={OG_IMAGE} />
  <BaseHead slug={`/hourly/${page.slug}/`} pageType="salary" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="alternate" hreflang="en-GB" href={canonical} />
  <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/inter-700.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="manifest" href="/manifest.webmanifest" />
  {schemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</head>
<body class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
  <a href="#main-content" class="skip-link bg-navy-600 text-white">Skip to content</a>
  <Header />

  <main id="main-content" class="mx-auto max-w-3xl px-4 py-8 sm:px-6 sm:py-12">
    <Breadcrumbs items={breadcrumbItems} />
    <article class="prose prose-gray dark:prose-invert max-w-none">

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- 1. H1 + Intro -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <h1>{page.hourlyFormatted} Per Hour After Tax UK {TAX_YEAR}</h1>

      <p>
        If you earn <strong>{page.hourlyFormatted} per hour</strong> in the United Kingdom, your gross annual salary
        equivalent is <strong>{page.annualFormatted}</strong> (based on a standard 37.5-hour working week). After income
        tax and National Insurance, your take-home pay is approximately <strong>{page.englandFormatted.netMonthly} per
        month</strong> or <strong>{page.englandFormatted.netHourly} per hour</strong> in England. This page provides a
        complete breakdown of your deductions, a band-by-band tax analysis, a Scotland comparison, and practical context
        for the {TAX_YEAR} tax year.
      </p>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- 2. Quick Summary Cards -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <div class="not-prose my-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
        <div class="rounded-lg border border-gray-200 p-4 text-center dark:border-gray-700">
          <div class="text-sm text-gray-500 dark:text-gray-400">Annual equivalent</div>
          <div class="mt-1 text-xl font-bold text-navy-700 dark:text-navy-300">{page.annualFormatted}</div>
        </div>
        <div class="rounded-lg border border-gray-200 p-4 text-center dark:border-gray-700">
          <div class="text-sm text-gray-500 dark:text-gray-400">Monthly take-home</div>
          <div class="mt-1 text-xl font-bold text-navy-700 dark:text-navy-300">{page.englandFormatted.netMonthly}</div>
        </div>
        <div class="rounded-lg border border-gray-200 p-4 text-center dark:border-gray-700">
          <div class="text-sm text-gray-500 dark:text-gray-400">Weekly take-home</div>
          <div class="mt-1 text-xl font-bold text-navy-700 dark:text-navy-300">{formatCurrency(weeklyNet)}</div>
        </div>
        <div class="rounded-lg border border-gray-200 p-4 text-center dark:border-gray-700">
          <div class="text-sm text-gray-500 dark:text-gray-400">Effective tax rate</div>
          <div class="mt-1 text-xl font-bold text-navy-700 dark:text-navy-300">{page.englandFormatted.effectiveTaxRate}</div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- 3. Tax Breakdown Table -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <h2>Tax Breakdown on {page.hourlyFormatted} Per Hour</h2>
      <p>
        Here is how your {page.hourlyFormatted} per hour ({page.annualFormatted} per year) salary is broken down in
        England, Wales, and Northern Ireland for the {TAX_YEAR} tax year:
      </p>
      <div class="overflow-x-auto">
        <table>
          <thead>
            <tr>
              <th>Item</th>
              <th class="text-right">Annual</th>
              <th class="text-right">Monthly</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Gross salary</td>
              <td class="text-right tabular-nums">{page.englandFormatted.grossAnnual}</td>
              <td class="text-right tabular-nums">{page.englandFormatted.grossMonthly}</td>
            </tr>
            <tr>
              <td>Income tax</td>
              <td class="text-right tabular-nums">{page.englandFormatted.incomeTax}</td>
              <td class="text-right tabular-nums">{formatCurrency(page.england.incomeTax / 12)}</td>
            </tr>
            <tr>
              <td>National Insurance</td>
              <td class="text-right tabular-nums">{page.englandFormatted.nationalInsurance}</td>
              <td class="text-right tabular-nums">{formatCurrency(page.england.nationalInsurance / 12)}</td>
            </tr>
            <tr>
              <td><strong>Total deductions</strong></td>
              <td class="text-right tabular-nums"><strong>{page.englandFormatted.totalDeductions}</strong></td>
              <td class="text-right tabular-nums"><strong>{formatCurrency(page.england.totalDeductions / 12)}</strong></td>
            </tr>
            <tr class="bg-accent-50 dark:bg-accent-500/10">
              <td><strong>Take-home pay</strong></td>
              <td class="text-right tabular-nums"><strong>{page.englandFormatted.netAnnual}</strong></td>
              <td class="text-right tabular-nums"><strong>{page.englandFormatted.netMonthly}</strong></td>
            </tr>
            <tr>
              <td>Effective tax rate</td>
              <td class="text-right" colspan="2">{page.englandFormatted.effectiveTaxRate}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- CTA -->
      <div class="not-prose my-8 text-center">
        <a
          href="/"
          data-gross={ctaGross}
          class="cta-calc inline-block rounded-lg bg-navy-600 px-6 py-3 text-lg font-semibold text-white shadow-md transition-colors hover:bg-navy-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-navy-600"
        >
          Calculate your exact take-home pay &rarr;
        </a>
      </div>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- 4. Income Tax Band-by-Band Breakdown -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      {page.england.incomeTaxBands.length > 0 && (
        <>
          <h2>Income Tax Band-by-Band Breakdown</h2>
          <p>
            The table below shows exactly how much of your {page.annualFormatted} annual salary falls in each income tax
            band for England, Wales, and Northern Ireland in {TAX_YEAR}:
          </p>
          <div class="overflow-x-auto">
            <table>
              <thead>
                <tr>
                  <th>Tax Band</th>
                  <th class="text-right">Rate</th>
                  <th class="text-right">Taxable Amount</th>
                  <th class="text-right">Tax</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Personal Allowance</td>
                  <td class="text-right">0%</td>
                  <td class="text-right tabular-nums">{formatCurrency(page.england.personalAllowance)}</td>
                  <td class="text-right tabular-nums">&pound;0</td>
                </tr>
                {page.england.incomeTaxBands.map((band) => (
                  <tr>
                    <td>{band.name}</td>
                    <td class="text-right">{(band.rate * 100).toFixed(0)}%</td>
                    <td class="text-right tabular-nums">{formatCurrency(band.taxableAmount)}</td>
                    <td class="text-right tabular-nums">{formatCurrency(band.tax)}</td>
                  </tr>
                ))}
                <tr class="font-semibold">
                  <td>Total</td>
                  <td class="text-right"></td>
                  <td class="text-right tabular-nums">{page.englandFormatted.grossAnnual}</td>
                  <td class="text-right tabular-nums">{page.englandFormatted.incomeTax}</td>
                </tr>
              </tbody>
            </table>
          </div>
        </>
      )}

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- 5. National Insurance Breakdown -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <h2>National Insurance on {page.hourlyFormatted} Per Hour</h2>
      {paysNI ? (
        <>
          <p>
            National Insurance Contributions (NICs) are calculated separately from income tax. For employees in
            the {TAX_YEAR} tax year, Class 1 NICs are charged at:
          </p>
          <ul>
            <li><strong>{(NI_MAIN_RATE * 100).toFixed(0)}%</strong> on earnings between {formatCurrency(NI_PRIMARY_THRESHOLD)} and {formatCurrency(NI_UPPER_EARNINGS_LIMIT)} per year</li>
            <li><strong>{(NI_ADDITIONAL_RATE * 100).toFixed(0)}%</strong> on earnings above {formatCurrency(NI_UPPER_EARNINGS_LIMIT)} per year</li>
          </ul>
          <p>
            On your annual salary equivalent of {page.annualFormatted}, National Insurance totals
            <strong>{page.englandFormatted.nationalInsurance}</strong> per year, or approximately
            {formatCurrency(page.england.nationalInsurance / 12)} per month.
          </p>
        </>
      ) : (
