  <script>
    // Append ?gross= only on real user clicks so crawlers never see query-string URLs.
    document.querySelectorAll('a.cta-calc').forEach((a) => {
      a.addEventListener('click', (e) => {
        const gross = (a as HTMLAnchorElement).dataset.gross;
        if (gross) {
          e.preventDefault();
          window.location.href = `/#gross=${gross}`;
        }
      });
    });
  </script>
</body>
</html>
