---
/**
 * Dynamic route for monthly salary landing pages.
 * Generates 59 static pages at build time (£100–£3,000 in £50 steps).
 */
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import BaseHead from '../../components/seo/BaseHead.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import '../../styles/global.css';
import { generateMonthlySalaryPages, type MonthlySalaryPageData } from '../../data/monthly-salary-pages';
import {
  buildTitle,
  buildCanonical,
  SITE_NAME,
  SITE_URL,
  OG_IMAGE,
  OG_IMAGE_WIDTH,
  OG_IMAGE_HEIGHT,
  breadcrumbSchema,
  articleSchema,
  faqSchema,
  organizationSchema,
  personSchema,
  LAST_UPDATED,
} from '../../lib/seo';
import { formatCurrency, formatPercent } from '../../lib/format';
import {
  PERSONAL_ALLOWANCE,
  NI_PRIMARY_THRESHOLD,
  NI_UPPER_EARNINGS_LIMIT,
  NI_MAIN_RATE,
  NI_ADDITIONAL_RATE,
  TAX_YEAR,
  INCOME_TAX_BANDS_ENGLAND,
} from '../../data/tax-rules-2026-27';

export function getStaticPaths() {
  const pages = generateMonthlySalaryPages();
  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

interface Props {
  page: MonthlySalaryPageData;
}

const { page } = Astro.props;

// ─── SEO ──────────────────────────────────────────────────────────────────
// Title: 50-60 chars, keyword-rich, no site name
const title = `£${page.monthly.toLocaleString('en-GB')} Per Month After Tax UK - Take Home Pay ${TAX_YEAR}`;
const metaTitle = buildTitle(title);
// Description: 150-160 chars, keyword-rich
const description = `Earning £${page.monthly.toLocaleString('en-GB')} per month? See your UK take home pay after income tax and NI for ${TAX_YEAR}. Full salary breakdown with tax bands, Scotland comparison and tips.`;
const canonical = buildCanonical(`/salary/${page.slug}`);

const breadcrumbItems = [
  { name: 'Home', url: SITE_URL },
  { name: 'Salary Pages', url: `${SITE_URL}/salary/` },
  { name: `£${page.monthly.toLocaleString('en-GB')} Per Month`, url: canonical },
];

const article = articleSchema({
  headline: title,
  description,
  url: canonical,
});

// ─── FAQs (unique per salary level) ─────────────────────────────────────
const faqs: { question: string; answer: string }[] = [];

if (page.tier === 'below-pa') {
  faqs.push(
    {
      question: `Do I pay tax on £${page.monthly.toLocaleString('en-GB')} a month?`,
      answer: `No. A salary of ${page.monthlyFormatted} per month equals ${page.annualFormatted} per year, which is below the ${TAX_YEAR} Personal Allowance of ${formatCurrency(PERSONAL_ALLOWANCE)}. You pay no income tax on this amount. However, you may still pay National Insurance if your earnings exceed ${formatCurrency(NI_PRIMARY_THRESHOLD)} per year.`,
    },
    {
      question: `How much is ${page.monthlyFormatted} a month per hour?`,
      answer: `Based on a standard 37.5-hour working week, ${page.monthlyFormatted} per month (${page.annualFormatted} per year) works out to approximately ${page.hourlyGross} per hour before any deductions.`,
    },
    {
      question: `Is ${page.monthlyFormatted} a month above minimum wage?`,
      answer: `The National Living Wage for 2026/27 is £12.21 per hour for workers aged 21 and over, which equates to roughly £23,808 per year or £1,984 per month for a 37.5-hour week. At ${page.monthlyFormatted} per month (${page.hourlyGross} per hour), this salary is ${page.annual >= 23808 ? 'at or above' : 'below'} the full-time minimum wage equivalent.`,
    },
  );
} else {
  faqs.push(
    {
      question: `What is the take-home pay on £${page.monthly.toLocaleString('en-GB')} a month?`,
      answer: `On a salary of ${page.monthlyFormatted} per month (${page.annualFormatted} per year) in England, your monthly take-home pay is approximately ${page.englandFormatted.netMonthly} after income tax and National Insurance deductions for the ${TAX_YEAR} tax year.`,
    },
    {
      question: `How much tax do I pay on ${page.monthlyFormatted} a month?`,
      answer: `On ${page.monthlyFormatted} per month (${page.annualFormatted} annual), you pay ${page.englandFormatted.incomeTax} in income tax and ${page.englandFormatted.nationalInsurance} in National Insurance per year. Your effective tax rate is ${page.englandFormatted.effectiveTaxRate}.`,
    },
    {
      question: `How much is ${page.monthlyFormatted} a month per hour?`,
      answer: `Based on a standard 37.5-hour working week, ${page.monthlyFormatted} per month (${page.annualFormatted} per year) works out to approximately ${page.hourlyGross} per hour before tax.`,
    },
    {
      question: `Is ${page.monthlyFormatted} a month a good salary in the UK?`,
      answer: `The UK median salary is approximately £35,000 per year (around £2,917 per month). At ${page.monthlyFormatted} per month (${page.annualFormatted} per year), this salary is ${page.annual >= 35000 ? 'at or above' : 'below'} the national median. Whether it is sufficient depends on your location, lifestyle, and financial commitments.`,
    },
  );
}

const faqStructuredData = faqSchema(faqs);

// ─── CTA ────────────────────────────────────────────────────────────────
// Link is plain "/" in static HTML so Google doesn't index query-string variants.
// JS adds ?gross= on click so the calculator is pre-filled for real users.
const ctaGross = page.annual;

// ─── Context helpers ────────────────────────────────────────────────────
const medianAnnual = 35000;
const medianMonthly = Math.round(medianAnnual / 12);
const percentOfMedian = Math.round((page.annual / medianAnnual) * 100);

// NI calculation details
const niThresholdMonthly = formatCurrency(NI_PRIMARY_THRESHOLD / 12);
const niUpperMonthly = formatCurrency(NI_UPPER_EARNINGS_LIMIT / 12);
const paysNI = page.annual > NI_PRIMARY_THRESHOLD;
const niableIncome = paysNI ? Math.min(page.annual, NI_UPPER_EARNINGS_LIMIT) - NI_PRIMARY_THRESHOLD : 0;

// Tax calculation details
const paysTax = page.annual > PERSONAL_ALLOWANCE;
const taxableIncome = paysTax ? page.annual - PERSONAL_ALLOWANCE : 0;

// Extended content helpers
const monthlyNet = page.england.netAnnual / 12;
const rentBudget30 = formatCurrency(monthlyNet * 0.3);
const mortgageMax = formatCurrency(page.annual * 4.5);
const emergencyFund3mo = formatCurrency(monthlyNet * 3);
const emergencyFund6mo = formatCurrency(monthlyNet * 6);
const savingsAt10pct = formatCurrency(monthlyNet * 0.1);
const hourlyNet = formatCurrency(page.england.netAnnual / (52 * 37.5));
const weeklyNet = formatCurrency(page.england.netAnnual / 52);
const dailyNet = formatCurrency(page.england.netAnnual / 365);
const hoursFor50 = Math.round(50 / (page.england.netAnnual / (52 * 37.5)));
const hoursFor500 = Math.round(500 / (page.england.netAnnual / (52 * 37.5)));
const lifeBracket = page.monthly <= 300 ? 'minimal' : page.monthly <= 700 ? 'parttime' : page.monthly <= 1050 ? 'nearpa' : page.monthly <= 1800 ? 'lower' : 'upper';
const regionBracket = page.monthly <= 700 ? 'low' : page.monthly <= 1500 ? 'mid' : 'high';
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{metaTitle}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Mottalib Radif" />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="article" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={SITE_NAME} />
  <meta property="og:locale" content="en_GB" />
  <meta property="og:image" content={OG_IMAGE} />
  <meta property="og:image:width" content={OG_IMAGE_WIDTH} />
  <meta property="og:image:height" content={OG_IMAGE_HEIGHT} />
  <meta property="og:image:alt" content={`£${page.monthly.toLocaleString('en-GB')} per month after tax UK - salary breakdown`} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={OG_IMAGE} />
  <BaseHead slug={`/salary/${page.slug}/`} pageType="salary" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/inter-700.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="manifest" href="/manifest.webmanifest" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbItems))} />
  <script type="application/ld+json" set:html={JSON.stringify(article)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema())} />
  <script type="application/ld+json" set:html={JSON.stringify(personSchema())} />
</head>
<body class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
  <a href="#main-content" class="skip-link bg-navy-600 text-white">Skip to content</a>
  <Header />

  <main id="main-content" class="mx-auto max-w-3xl px-4 py-8 sm:px-6 sm:py-12">
    <Breadcrumbs items={breadcrumbItems} />
    <article class="prose prose-gray dark:prose-invert max-w-none">

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- 1. H1 + Intro -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <h1>£{page.monthly.toLocaleString('en-GB')} Per Month After Tax: UK Take-Home Pay Breakdown</h1>

      {page.tier === 'below-pa' ? (
        <p>
          If you earn <strong>{page.monthlyFormatted} per month</strong> in the United Kingdom, your annual gross salary
          is <strong>{page.annualFormatted}</strong>. Because this is below the {TAX_YEAR} Personal Allowance
          of {formatCurrency(PERSONAL_ALLOWANCE)}, <strong>you pay no income tax</strong> on this salary. This page
          breaks down exactly what happens to your pay, whether you owe National Insurance, and how your take-home
          compares to nearby salary levels. All figures use official HMRC rates for the {TAX_YEAR} tax year.
        </p>
      ) : (
        <p>
          If you earn <strong>{page.monthlyFormatted} per month</strong> in the United Kingdom, your annual gross salary
          is <strong>{page.annualFormatted}</strong>. After income tax and National Insurance, your monthly take-home pay
          is approximately <strong>{page.englandFormatted.netMonthly}</strong> in England. This page provides a complete
          breakdown of your deductions, band-by-band tax analysis, a Scotland comparison, and practical context for
          the {TAX_YEAR} tax year.
        </p>
      )}

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- 2. Summary Results Table -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <h2>Your {page.monthlyFormatted} Salary at a Glance</h2>
      <div class="overflow-x-auto">
        <table>
          <thead>
            <tr>
              <th>Item</th>
              <th class="text-right">Annual</th>
              <th class="text-right">Monthly</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Gross salary</td>
              <td class="text-right tabular-nums">{page.englandFormatted.grossAnnual}</td>
              <td class="text-right tabular-nums">{page.englandFormatted.grossMonthly}</td>
            </tr>
            <tr>
              <td>Income tax</td>
              <td class="text-right tabular-nums">{page.englandFormatted.incomeTax}</td>
              <td class="text-right tabular-nums">{formatCurrency(page.england.incomeTax / 12)}</td>
            </tr>
            <tr>
              <td>National Insurance</td>
              <td class="text-right tabular-nums">{page.englandFormatted.nationalInsurance}</td>
              <td class="text-right tabular-nums">{formatCurrency(page.england.nationalInsurance / 12)}</td>
            </tr>
            <tr>
              <td><strong>Total deductions</strong></td>
              <td class="text-right tabular-nums"><strong>{page.englandFormatted.totalDeductions}</strong></td>
              <td class="text-right tabular-nums"><strong>{formatCurrency(page.england.totalDeductions / 12)}</strong></td>
            </tr>
            <tr class="bg-accent-50 dark:bg-accent-500/10">
              <td><strong>Take-home pay</strong></td>
              <td class="text-right tabular-nums"><strong>{page.englandFormatted.netAnnual}</strong></td>
              <td class="text-right tabular-nums"><strong>{page.englandFormatted.netMonthly}</strong></td>
            </tr>
            <tr>
              <td>Effective tax rate</td>
              <td class="text-right" colspan="2">{page.englandFormatted.effectiveTaxRate}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- 3. CTA Button -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <div class="not-prose my-8 text-center">
        <a
          href="/"
          data-gross={ctaGross}
          class="cta-calc inline-block rounded-lg bg-navy-600 px-6 py-3 text-lg font-semibold text-white shadow-md transition-colors hover:bg-navy-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-navy-600"
        >
          Calculate your exact take-home pay &rarr;
        </a>
      </div>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- 4. How Your Salary Is Taxed -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <h2>How Your {page.monthlyFormatted}/Month Salary Is Taxed</h2>

      {page.tier === 'below-pa' ? (
        <>
          <p>
            Your annual salary of {page.annualFormatted} falls entirely within the <strong>Personal Allowance</strong>,
            which is the amount you can earn tax-free each year. For the {TAX_YEAR} tax year, the Personal Allowance
            is <strong>{formatCurrency(PERSONAL_ALLOWANCE)}</strong>.
          </p>
          <p>
            Since {page.annualFormatted} is less than {formatCurrency(PERSONAL_ALLOWANCE)}, your entire income is
            covered by the Personal Allowance. This means:
          </p>
          <ul>
            <li><strong>Income tax: {page.englandFormatted.incomeTax}:</strong> no tax is due because your salary is below the tax-free threshold.</li>
            {paysNI ? (
              <li>
                <strong>National Insurance: {page.englandFormatted.nationalInsurance} per year:</strong>
                you still pay NI because the NI threshold ({formatCurrency(NI_PRIMARY_THRESHOLD)}/year) is the same as the Personal
                Allowance, but your earnings above this threshold are subject to the {(NI_MAIN_RATE * 100).toFixed(0)}% rate.
              </li>
            ) : (
              <li>
                <strong>National Insurance: {page.englandFormatted.nationalInsurance}:</strong>
                your salary is also below the NI Primary Threshold of {formatCurrency(NI_PRIMARY_THRESHOLD)}/year,
                so no NI is due either.
              </li>
            )}
          </ul>
          <p>
            Even though no income tax is deducted, your employer will still operate PAYE (Pay As You Earn) and report
            your earnings to HMRC. You will receive a tax code (typically 1257L) which tells your employer
            that you have the full Personal Allowance available.
          </p>
          <p>
            If this is a second job, your tax code may differ (e.g., BR), which could mean tax is deducted even on
            income below the Personal Allowance. You can reclaim any overpaid tax through HMRC.
          </p>
        </>
      ) : (
        <>
          <p>
            Understanding how UK income tax works on your {page.monthlyFormatted} monthly salary helps you see exactly
            where your money goes. The UK uses a <strong>progressive tax system</strong>, meaning different portions of
            your income are taxed at different rates.
          </p>
          <p>Here is how your {page.annualFormatted} annual salary is broken down step by step:</p>
          <ol>
            <li>
              <strong>Personal Allowance ({formatCurrency(PERSONAL_ALLOWANCE)}):</strong> The first {formatCurrency(PERSONAL_ALLOWANCE)} of your
              income is tax-free. This is your Personal Allowance for {TAX_YEAR}.
            </li>
            <li>
              <strong>Basic Rate at 20%:</strong> Income above the Personal Allowance up to £50,270 is taxed at 20%.
              For your salary, that means {formatCurrency(taxableIncome)} is taxed at the basic rate, producing
              {page.englandFormatted.incomeTax} in income tax.
            </li>
          </ol>
          <p>
            Your total income tax for the year is <strong>{page.englandFormatted.incomeTax}</strong>,
            or {formatCurrency(page.england.incomeTax / 12)} per month.
          </p>
        </>
      )}

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- 5. Band-by-Band Analysis (taxable salaries only) -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      {page.tier === 'basic-rate' && page.england.incomeTaxBands.length > 0 && (
        <>
          <h2>Income Tax Band-by-Band Breakdown</h2>
          <p>
            The table below shows exactly how much of your {page.annualFormatted} salary falls in each income tax
            band for England, Wales, and Northern Ireland in {TAX_YEAR}:
          </p>
          <div class="overflow-x-auto">
            <table>
              <thead>
                <tr>
                  <th>Tax Band</th>
                  <th class="text-right">Rate</th>
                  <th class="text-right">Taxable Amount</th>
                  <th class="text-right">Tax</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Personal Allowance</td>
                  <td class="text-right">0%</td>
                  <td class="text-right tabular-nums">{formatCurrency(page.england.personalAllowance)}</td>
                  <td class="text-right tabular-nums">£0</td>
                </tr>
                {page.england.incomeTaxBands.map((band) => (
                  <tr>
                    <td>{band.name}</td>
                    <td class="text-right">{(band.rate * 100).toFixed(0)}%</td>
                    <td class="text-right tabular-nums">{formatCurrency(band.taxableAmount)}</td>
                    <td class="text-right tabular-nums">{formatCurrency(band.tax)}</td>
                  </tr>
                ))}
                <tr class="font-semibold">
                  <td>Total</td>
                  <td class="text-right"></td>
                  <td class="text-right tabular-nums">{page.englandFormatted.grossAnnual}</td>
                  <td class="text-right tabular-nums">{page.englandFormatted.incomeTax}</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p>
            As the table shows, only the portion of your salary above the {formatCurrency(PERSONAL_ALLOWANCE)} Personal
            Allowance is actually taxed. The first {formatCurrency(PERSONAL_ALLOWANCE)} is entirely tax-free, and the
            remaining {formatCurrency(taxableIncome)} is taxed at 20% (the basic rate).
          </p>
        </>
      )}

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- 6. National Insurance Breakdown -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <h2>National Insurance on {page.monthlyFormatted} Per Month</h2>
      {paysNI ? (
        <>
          <p>
            National Insurance Contributions (NICs) are calculated separately from income tax. For employees in
            the {TAX_YEAR} tax year, Class 1 NICs are charged at:
          </p>
          <ul>
            <li><strong>{(NI_MAIN_RATE * 100).toFixed(0)}%</strong> on earnings between {formatCurrency(NI_PRIMARY_THRESHOLD)} and {formatCurrency(NI_UPPER_EARNINGS_LIMIT)} per year</li>
            <li><strong>{(NI_ADDITIONAL_RATE * 100).toFixed(0)}%</strong> on earnings above {formatCurrency(NI_UPPER_EARNINGS_LIMIT)} per year</li>
          </ul>
          <p>
            On your annual salary of {page.annualFormatted}, National Insurance is calculated as follows:
          </p>
          <ul>
            <li>Earnings below {formatCurrency(NI_PRIMARY_THRESHOLD)}: no NI due (this is the Primary Threshold).</li>
            <li>
              Earnings from {formatCurrency(NI_PRIMARY_THRESHOLD)} to {formatCurrency(Math.min(page.annual, NI_UPPER_EARNINGS_LIMIT))}:
              {formatCurrency(niableIncome)} &times; {(NI_MAIN_RATE * 100).toFixed(0)}% = <strong>{formatCurrency(niableIncome * NI_MAIN_RATE)}</strong>.
            </li>
          </ul>
          <p>
            Your total NI for the year is <strong>{page.englandFormatted.nationalInsurance}</strong>,
            or approximately {formatCurrency(page.england.nationalInsurance / 12)} per month. National Insurance
            contributions help fund the State Pension, NHS, and other benefits.
          </p>
        </>
      ) : (
        <>
          <p>
            National Insurance Contributions (NICs) for employees are charged on earnings above the Primary Threshold,
            which is {formatCurrency(NI_PRIMARY_THRESHOLD)} per year for {TAX_YEAR}. Since your annual salary of
            {page.annualFormatted} is at or below this threshold, <strong>you pay no National Insurance</strong>.
          </p>
          <p>
            However, you may still build up qualifying years for the State Pension if your earnings are above the
            Lower Earnings Limit of £6,708 per year ({page.annual >= 6708 ? 'which your salary exceeds' : 'which your salary is below'}).
          </p>
        </>
      )}

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- 7. Period Breakdown Table -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <h2>What You Take Home Each Pay Period</h2>
      <p>
        Here is what {page.monthlyFormatted} per month looks like across different pay periods, showing both your
        gross (before-tax) and net (after-tax) amounts for England in {TAX_YEAR}:
      </p>
      <div class="overflow-x-auto">
        <table>
          <thead>
            <tr>
              <th>Period</th>
              <th class="text-right">Gross</th>
              <th class="text-right">Take-Home</th>
            </tr>
          </thead>
          <tbody>
            {page.periods.map((p) => (
              <tr>
                <td>{p.label}</td>
                <td class="text-right tabular-nums">{p.gross}</td>
                <td class="text-right tabular-nums">{p.net}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p>
        At {page.monthlyFormatted} per month gross, your effective hourly rate is {page.hourlyGross} before tax
        (based on a 37.5-hour week), or approximately {formatCurrency(page.england.netAnnual / (52 * 37.5))} per
        hour after tax. Your daily take-home is roughly {formatCurrency(page.england.netAnnual / 365)}.
      </p>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- 8. Scotland Comparison -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <h2>England vs Scotland: {page.monthlyFormatted} Per Month Comparison</h2>
      <p>
        Scotland has its own income tax rates that differ from England, Wales, and Northern Ireland. If you live in
        Scotland and earn {page.monthlyFormatted} per month, your take-home pay may differ. National Insurance rates
        are the same across the UK. Here is the comparison:
      </p>
      <div class="overflow-x-auto">
        <table>
          <thead>
            <tr>
              <th>Item</th>
              <th class="text-right">England</th>
              <th class="text-right">Scotland</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Gross annual</td>
              <td class="text-right tabular-nums">{page.englandFormatted.grossAnnual}</td>
              <td class="text-right tabular-nums">{page.scotlandFormatted.grossAnnual}</td>
            </tr>
            <tr>
              <td>Income tax</td>
              <td class="text-right tabular-nums">{page.englandFormatted.incomeTax}</td>
              <td class="text-right tabular-nums">{page.scotlandFormatted.incomeTax}</td>
            </tr>
            <tr>
              <td>National Insurance</td>
              <td class="text-right tabular-nums">{page.englandFormatted.nationalInsurance}</td>
              <td class="text-right tabular-nums">{page.scotlandFormatted.nationalInsurance}</td>
            </tr>
            <tr>
              <td>Total deductions</td>
              <td class="text-right tabular-nums">{page.englandFormatted.totalDeductions}</td>
              <td class="text-right tabular-nums">{page.scotlandFormatted.totalDeductions}</td>
            </tr>
            <tr class="bg-accent-50 dark:bg-accent-500/10">
              <td><strong>Net annual</strong></td>
