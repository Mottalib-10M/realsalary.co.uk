---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import BaseHead from '../components/seo/BaseHead.astro';
import Breadcrumbs from '../components/ui/Breadcrumbs.astro';
import '../styles/global.css';
import { buildCanonical, SITE_NAME, SITE_URL, OG_IMAGE, OG_IMAGE_WIDTH, OG_IMAGE_HEIGHT, breadcrumbSchema, organizationSchema, personSchema, LAST_UPDATED } from '../lib/seo';

const title = 'All UK Salary & Tax Calculators 2026/27 | Free Online Tools';
const description = 'Free UK salary, tax, NI, pension, student loan and bonus calculators for the 2026/27 tax year. HMRC-verified rates, instant results, no sign-up required.';
const canonical = buildCanonical('/calculators/');

const breadcrumbItems = [
  { name: 'Home', url: SITE_URL },
  { name: 'All Calculators', url: canonical },
];

const schemas = [
  breadcrumbSchema(breadcrumbItems),
  organizationSchema(),
  personSchema(),
];

const calculators = [
  {
    category: 'Salary & Pay',
    items: [
      { href: '/', name: 'Salary Calculator', desc: 'Full breakdown of income tax, NI and take-home pay from your annual salary' },
      { href: '/take-home-pay/', name: 'Take-Home Pay Calculator', desc: 'See exactly what lands in your bank account each month' },
      { href: '/hourly-rate/', name: 'Hourly Rate Calculator', desc: 'Convert annual or monthly salary to an hourly rate, gross and net' },
      { href: '/pro-rata/', name: 'Pro-Rata Salary Calculator', desc: 'Calculate part-time salary based on full-time equivalent and hours' },
      { href: '/required-salary/', name: 'Required Salary Calculator', desc: 'Find the gross salary needed to achieve a target take-home amount' },
    ],
  },
  {
    category: 'Tax & Deductions',
    items: [
      { href: '/income-tax/', name: 'Income Tax Calculator', desc: 'Calculate income tax across all bands for England, Wales, NI and Scotland' },
      { href: '/national-insurance/', name: 'National Insurance Calculator', desc: 'Employee and employer NI contributions with Class 1 breakdown' },
      { href: '/student-loan/', name: 'Student Loan Calculator', desc: 'Repayment amounts for Plan 1, 2, 4, 5 and postgraduate loans' },
      { href: '/bonus/', name: 'Bonus Tax Calculator', desc: 'See how much tax you pay on a one-off bonus payment' },
      { href: '/two-jobs/', name: 'Two Jobs Tax Calculator', desc: 'Calculate combined tax and NI when holding two employment positions' },
    ],
  },
  {
    category: 'Pension & Retirement',
    items: [
      { href: '/pension-contribution/', name: 'Pension Contribution Calculator', desc: 'Compare salary sacrifice vs relief at source pension contributions' },
    ],
  },
];
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Mottalib Radif" />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={SITE_NAME} />
  <meta property="og:locale" content="en_GB" />
  <meta property="og:image" content={OG_IMAGE} />
  <meta property="og:image:width" content={OG_IMAGE_WIDTH} />
  <meta property="og:image:height" content={OG_IMAGE_HEIGHT} />
  <meta property="og:image:alt" content="All UK Salary and Tax Calculators - free online tools" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={OG_IMAGE} />
  <BaseHead slug="/calculators/" pageType="hub" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/inter-700.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="manifest" href="/manifest.webmanifest" />
  {schemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</head>
<body class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100">
  <a href="#main-content" class="skip-link bg-navy-600 text-white">Skip to content</a>
  <Header />

  <main id="main-content" class="mx-auto max-w-5xl px-4 py-8 sm:px-6 sm:py-12">
    <Breadcrumbs items={breadcrumbItems} />
    <header class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl dark:text-white">All Calculators</h1>
      <p class="mt-3 text-lg text-gray-500 dark:text-gray-400">
        Free UK salary and tax calculators for the 2026/27 tax year. HMRC-verified rates, instant results, no sign-up required.
      </p>
    </header>

    <div class="space-y-10">
      {calculators.map((cat) => (
        <section>
          <h2 class="mb-5 text-xl font-bold text-gray-900 dark:text-white">{cat.category}</h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {cat.items.map((calc) => (
              <a href={calc.href} class="group rounded-lg border border-gray-200 p-4 transition-colors hover:border-navy-300 hover:bg-navy-50 dark:border-gray-700 dark:hover:border-navy-600 dark:hover:bg-gray-800">
                <h3 class="font-semibold text-gray-900 group-hover:text-navy-700 dark:text-white dark:group-hover:text-navy-300">{calc.name}</h3>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{calc.desc}</p>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <p class="mt-8 text-sm text-gray-400 dark:text-gray-500">{LAST_UPDATED}</p>
  </main>

  <Footer />
</body>
</html>
